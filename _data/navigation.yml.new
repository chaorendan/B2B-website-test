# Google Ads B2B 知识库导航配置
# 版本: v1.0
# 说明: 此文件为新版导航配置示例，确认后可替换 navigation.yml

main:
  - title: "Google Ads"
    url: /google-ads/
    children:
      - title: "📚 基础篇"
        url: /knowledge/google-ads/01-fundamentals/
        description: "账户结构、广告系列类型、质量得分"
      
      - title: "🔍 搜索广告"
        url: /knowledge/google-ads/02-search-campaigns/
        description: "关键词研究、匹配类型、出价策略"
      
      - title: "🎯 展示与再营销"
        url: /knowledge/google-ads/03-display-remarketing/
        description: "展示广告、再营销策略、受众定位"
      
      - title: "📺 视频广告"
        url: /knowledge/google-ads/04-video-youtube/
        description: "YouTube 广告、视频格式、创意制作"
      
      - title: "⚡ Performance Max"
        url: /knowledge/google-ads/05-performance-max/
        description: "PMax 设置、Feed 优化、受众信号"
      
      - title: "🏢 B2B 专项策略"
        url: /knowledge/google-ads/06-b2b-strategies/
        description: "线索生成、长销售周期、ABM 策略"
      
      - title: "📊 追踪与分析"
        url: /knowledge/google-ads/07-tracking-analytics/
        description: "转化追踪、增强型转化、归因模型"
      
      - title: "🚀 优化技巧"
        url: /knowledge/google-ads/08-optimization/
        description: "A/B 测试、自动化规则、脚本"
      
      - title: "🔧 故障排除"
        url: /knowledge/google-ads/09-troubleshooting/
        description: "常见问题诊断与解决方案"

  - title: "GA4"
    url: /ga4/

  - title: "Projects"
    url: /projects/

  - title: "About"
    url: /about/

